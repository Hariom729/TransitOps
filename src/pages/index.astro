---
import Layout from '../layouts/Layout.astro';
import Card from '../components/ui/Card.astro';
import Badge from '../components/ui/Badge.astro';
import Button from '../components/ui/Button.astro';
import { db } from '../db';
import { vehicles, trips, drivers } from '../db/schema';

// We try-catch in case DB isn't initialized yet
let allVehicles = [];
let allTrips = [];
let allDrivers = [];

try {
  allVehicles = db.select().from(vehicles).all();
  allTrips = db.select().from(trips).all();
  allDrivers = db.select().from(drivers).all();
} catch (e) {
  console.log("DB not initialized yet.");
}

const filterType = Astro.url.searchParams.get('type') || '';
const filterStatus = Astro.url.searchParams.get('status') || '';

const filteredVehicles = allVehicles.filter(v => {
  if (filterType && v.type !== filterType) return false;
  if (filterStatus && v.status !== filterStatus) return false;
  return true;
});

const activeVehicles = filteredVehicles.filter(v => v.status === 'On Trip').length;
const availableVehicles = filteredVehicles.filter(v => v.status === 'Available').length;
const maintenanceVehicles = filteredVehicles.filter(v => v.status === 'In Shop').length;

const activeTrips = allTrips.filter(t => t.status === 'Dispatched').length;
const pendingTrips = allTrips.filter(t => t.status === 'Draft').length;

const driversOnDuty = allDrivers.filter(d => d.status === 'On Trip' || d.status === 'Available').length;
const fleetUtilization = filteredVehicles.length > 0 ? ((activeVehicles / filteredVehicles.length) * 100).toFixed(1) : 0;
---

<Layout title="Dashboard">
  <div class="p-lg md:p-xl lg:p-4xl space-y-xl relative">
    <header class="flex flex-col xl:flex-row justify-between items-start xl:items-end gap-md">
      <div>
        <h1 class="text-display-lg text-ink mb-xs">Command Center</h1>
        <p class="text-body-lg text-body">Real-time overview of your transport operations.</p>
      </div>
      <div class="flex flex-col sm:flex-row gap-sm items-start sm:items-end w-full xl:w-auto">
        <form method="get" class="flex gap-2">
          <select name="type" class="h-10 px-sm bg-canvas text-ink border border-hairline rounded-sm text-body-sm focus-visible:outline-none focus-visible:border-ink w-32">
            <option value="">All Types</option>
            <option value="Van" selected={filterType === 'Van'}>Van</option>
            <option value="Truck" selected={filterType === 'Truck'}>Truck</option>
            <option value="Car" selected={filterType === 'Car'}>Car</option>
          </select>
          <select name="status" class="h-10 px-sm bg-canvas text-ink border border-hairline rounded-sm text-body-sm focus-visible:outline-none focus-visible:border-ink w-32">
            <option value="">All Statuses</option>
            <option value="Available" selected={filterStatus === 'Available'}>Available</option>
            <option value="On Trip" selected={filterStatus === 'On Trip'}>On Trip</option>
            <option value="In Shop" selected={filterStatus === 'In Shop'}>In Shop</option>
          </select>
          <Button type="submit" variant="secondary" size="md" class="h-10">Filter</Button>
        </form>
        <a href="/trips">
          <Button variant="primary" size="md" class="h-10">Dispatch Trip</Button>
        </a>
      </div>
    </header>

    <!-- Mesh Gradient Hero Background Simulation -->
    <div class="absolute top-[-100px] left-0 w-full h-[600px] opacity-[0.15] -z-10 pointer-events-none" style="background: radial-gradient(circle at 15% 50%, var(--color-violet), transparent 50%), radial-gradient(circle at 85% 30%, var(--color-highlight-pink), transparent 50%), radial-gradient(circle at 50% 80%, var(--color-cyan), transparent 50%); filter: blur(80px);"></div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-md">
      <Card variant="soft" class="flex flex-col gap-xs min-h-[160px]">
        <span class="text-caption-mono text-body uppercase">Fleet Utilization</span>
        <div class="text-display-xl tracking-tighter text-ink mt-auto">{fleetUtilization}%</div>
        <span class="text-body-sm text-body">{activeVehicles} active of {filteredVehicles.length} total</span>
      </Card>
      
      <Card variant="soft" class="flex flex-col gap-xs min-h-[160px]">
        <span class="text-caption-mono text-body uppercase">Vehicles Status</span>
        <div class="flex flex-col items-start gap-xs mt-auto">
           <Badge class="bg-success/10 text-success !px-sm">{availableVehicles} Available</Badge>
           <Badge class="bg-warning/10 text-warning !px-sm">{maintenanceVehicles} In Shop</Badge>
        </div>
      </Card>

      <Card variant="soft" class="flex flex-col gap-xs min-h-[160px]">
        <span class="text-caption-mono text-body uppercase">Active Trips</span>
        <div class="text-display-lg text-ink mt-auto">{activeTrips}</div>
        <span class="text-body-sm text-body">{pendingTrips} Pending Drafts</span>
      </Card>

      <Card variant="soft" class="flex flex-col gap-xs min-h-[160px]">
        <span class="text-caption-mono text-body uppercase">Drivers</span>
        <div class="text-display-lg text-ink mt-auto">{driversOnDuty}</div>
        <span class="text-body-sm text-body">Available or On Duty</span>
      </Card>
    </div>

    <section class="space-y-md">
      <h2 class="text-display-md text-ink">Recent Activity</h2>
      <Card variant="marketing">
        <div class="text-center py-xl text-body flex flex-col items-center gap-sm">
          <p>No recent activity detected.</p>
          <a href="/vehicles"><Button variant="secondary" size="md">Register Vehicle</Button></a>
        </div>
      </Card>
    </section>
  </div>
</Layout>

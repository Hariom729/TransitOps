---
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/ui/Card.astro';
import Button from '../../components/ui/Button.astro';
import Badge from '../../components/ui/Badge.astro';
import Input from '../../components/ui/Input.astro';
import { db } from '../../db';
import { trips, vehicles, drivers, fuelLogs } from '../../db/schema';
import { eq } from 'drizzle-orm';

const allVehicles = db.select().from(vehicles).all();
const allDrivers = db.select().from(drivers).all();
const availableVehicles = allVehicles.filter(v => v.status === 'Available');
const availableDrivers = allDrivers.filter(d => d.status === 'Available' && new Date(d.licenseExpiryDate) >= new Date());

// Form Handling
let errorMessage = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action');

  if (action === 'create') {
    const vehicleId = formData.get('vehicleId') as string;
    const driverId = formData.get('driverId') as string;
    const cargoWeight = Number(formData.get('cargoWeight'));
    const vehicle = allVehicles.find(v => v.id === vehicleId);

    if (vehicle && cargoWeight > vehicle.maxLoadCapacity) {
      errorMessage = `Cargo weight (${cargoWeight}kg) exceeds vehicle capacity (${vehicle.maxLoadCapacity}kg).`;
    } else {
      await db.insert(trips).values({
        id: crypto.randomUUID(),
        source: formData.get('source') as string,
        destination: formData.get('destination') as string,
        vehicleId,
        driverId,
        cargoWeight,
        plannedDistance: Number(formData.get('plannedDistance')),
        status: 'Draft',
        createdAt: new Date().toISOString(),
      });
      // Refresh page to show new trip
      return Astro.redirect('/trips');
    }
  } else if (action === 'dispatch') {
    const tripId = formData.get('tripId') as string;
    const trip = db.select().from(trips).where(eq(trips.id, tripId)).get();
    
    if (trip) {
      // Update trip
      await db.update(trips).set({ status: 'Dispatched' }).where(eq(trips.id, tripId));
      // Update driver & vehicle
      await db.update(vehicles).set({ status: 'On Trip' }).where(eq(vehicles.id, trip.vehicleId));
      await db.update(drivers).set({ status: 'On Trip' }).where(eq(drivers.id, trip.driverId));
    }
  } else if (action === 'complete') {
    const tripId = formData.get('tripId') as string;
    const finalOdometer = Number(formData.get('finalOdometer'));
    const fuelLiters = Number(formData.get('fuelLiters'));
    const fuelCost = Number(formData.get('fuelCost'));

    const trip = db.select().from(trips).where(eq(trips.id, tripId)).get();
    
    if (trip) {
      await db.update(trips).set({ 
        status: 'Completed', 
        completedAt: new Date().toISOString(),
        fuelConsumed: fuelLiters,
        finalOdometer: finalOdometer
      }).where(eq(trips.id, tripId));

      await db.update(vehicles).set({ 
        status: 'Available',
        odometer: finalOdometer
      }).where(eq(vehicles.id, trip.vehicleId));

      await db.update(drivers).set({ status: 'Available' }).where(eq(drivers.id, trip.driverId));

      await db.insert(fuelLogs).values({
        id: crypto.randomUUID(),
        vehicleId: trip.vehicleId,
        tripId: trip.id,
        liters: fuelLiters,
        cost: fuelCost,
        date: new Date().toISOString(),
      });
    }
  } else if (action === 'cancel') {
    const tripId = formData.get('tripId') as string;
    const trip = db.select().from(trips).where(eq(trips.id, tripId)).get();
    
    if (trip) {
      await db.update(trips).set({ status: 'Cancelled' }).where(eq(trips.id, tripId));
      if (trip.status === 'Dispatched') {
        await db.update(vehicles).set({ status: 'Available' }).where(eq(vehicles.id, trip.vehicleId));
        await db.update(drivers).set({ status: 'Available' }).where(eq(drivers.id, trip.driverId));
      }
    }
  }
}

const allTrips = db.select().from(trips).all();
---

<Layout title="Trips">
  <div class="p-lg md:p-xl lg:p-4xl space-y-xl">
    <header class="flex justify-between items-end">
      <div>
        <h1 class="text-display-lg text-ink">Trip Management</h1>
        <p class="text-body-lg text-body">Dispatch and monitor active deliveries.</p>
      </div>
    </header>

    {errorMessage && (
      <div class="bg-error-soft text-error-deep p-md rounded-md text-body-md border border-error/20">
        {errorMessage}
      </div>
    )}

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-lg">
      <div class="space-y-xl lg:pr-md">
        <div>
          <h3 class="text-body-sm-strong text-body mb-md uppercase tracking-wider">Trip Lifecycle</h3>
          <div class="relative w-full pt-2">
            <div class="absolute left-[10%] right-[10%] top-3 h-[2px] bg-hairline z-0"></div>
            <div class="flex justify-between w-full relative z-10">
              <div class="flex flex-col items-center gap-2">
                <div class="w-3 h-3 rounded-full bg-success ring-4 ring-canvas"></div>
                <span class="text-xs text-success font-medium">Draft</span>
              </div>
              <div class="flex flex-col items-center gap-2">
                <div class="w-3 h-3 rounded-full bg-link ring-4 ring-canvas"></div>
                <span class="text-xs text-link font-medium">Dispatched</span>
              </div>
              <div class="flex flex-col items-center gap-2">
                <div class="w-3 h-3 rounded-full bg-mute ring-4 ring-canvas"></div>
                <span class="text-xs text-mute font-medium">Completed</span>
              </div>
              <div class="flex flex-col items-center gap-2">
                <div class="w-3 h-3 rounded-full bg-error ring-4 ring-canvas"></div>
                <span class="text-xs text-error font-medium">Cancelled</span>
              </div>
            </div>
          </div>
        </div>

        <Card variant="marketing" class="sticky top-24">
          <h2 class="text-display-md text-ink mb-md">Create Trip</h2>
          <form method="post" class="space-y-md">
            <input type="hidden" name="action" value="create" />
            <Input name="source" label="Source location" placeholder="Warehouse A" required />
            <Input name="destination" label="Destination" placeholder="Store 04" required />
            
            <div class="flex flex-col gap-2">
              <label class="text-body-sm-strong text-ink">Vehicle</label>
              <select name="vehicleId" required class="h-10 px-sm bg-canvas text-ink border border-hairline rounded-sm text-body-sm focus-visible:outline-none focus-visible:border-ink">
                <option value="" disabled selected>Select a vehicle...</option>
                {availableVehicles.map(v => (
                  <option value={v.id}>{v.nameModel} ({v.type}) - Max: {v.maxLoadCapacity}kg</option>
                ))}
                {availableVehicles.length === 0 && <option disabled>No available vehicles</option>}
              </select>
            </div>
            
            <div class="flex flex-col gap-2">
              <label class="text-body-sm-strong text-ink">Driver</label>
              <select name="driverId" required class="h-10 px-sm bg-canvas text-ink border border-hairline rounded-sm text-body-sm focus-visible:outline-none focus-visible:border-ink">
                <option value="" disabled selected>Select a driver...</option>
                {availableDrivers.map(d => (
                  <option value={d.id}>{d.name} ({d.licenseCategory})</option>
                ))}
                {availableDrivers.length === 0 && <option disabled>No available drivers</option>}
              </select>
            </div>

            <Input type="number" name="cargoWeight" label="Cargo Weight (kg)" placeholder="400" required />
            <Input type="number" name="plannedDistance" label="Planned Distance (km)" placeholder="15" required />
            
            <Button type="submit" variant="primary" class="w-full mt-sm" disabled={availableVehicles.length === 0 || availableDrivers.length === 0}>Create Draft</Button>
          </form>
        </Card>
      </div>

      <div class="lg:col-span-2 space-y-md">
        <h2 class="text-display-md text-ink mb-md">Live Board</h2>
        {allTrips.length === 0 ? (
          <Card variant="marketing">
            <p class="text-body text-center py-xl">No trips created yet. Draft one below.</p>
          </Card>
        ) : (
          <div class="flex flex-col gap-sm">
            {allTrips.map(t => {
               const v = allVehicles.find(v => v.id === t.vehicleId);
               const d = allDrivers.find(d => d.id === t.driverId);
               const shortId = `TR-${t.id.substring(0, 4).toUpperCase()}`;
               
               return (
                <Card variant="soft" class="flex flex-col px-lg py-md gap-4">
                  <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-4">
                    <div class="space-y-2">
                      <div class="text-caption-mono text-body">{shortId}</div>
                      <div class="text-body-md-strong text-ink">{t.source} → {t.destination}</div>
                      <div>
                        <Badge class={t.status === 'Completed' ? 'bg-success/10 text-success' : t.status === 'Dispatched' ? 'bg-link/10 text-link' : t.status === 'Cancelled' ? 'bg-error/10 text-error' : 'bg-mute/10 text-mute'}>{t.status}</Badge>
                      </div>
                    </div>
                    <div class="flex flex-col sm:items-end space-y-2">
                      <div class="text-body-sm text-body uppercase tracking-wide">
                        {v ? `${v.nameModel} (${v.type})` : 'Unassigned'} / {d ? d.name.split(' ')[0].toUpperCase() : 'Unassigned'}
                      </div>
                      <div class="text-caption text-mute">
                        {t.status === 'Draft' ? 'Awaiting dispatch' : t.status === 'Dispatched' ? `${t.plannedDistance} km` : t.status === 'Completed' ? 'Trip finished' : 'Cancelled'}
                      </div>
                    </div>
                  </div>
                  <div class="flex gap-2 justify-end pt-2 border-t border-hairline mt-2">
                    {t.status === 'Draft' && (
                      <form method="post" class="flex gap-2">
                        <input type="hidden" name="tripId" value={t.id} />
                        <Button type="submit" name="action" value="dispatch" variant="primary" size="sm">Dispatch</Button>
                        <Button type="submit" name="action" value="cancel" variant="secondary" size="sm">Cancel</Button>
                      </form>
                    )}
                    {t.status === 'Dispatched' && (
                      <div class="flex gap-2">
                        <Button type="button" variant="primary" size="sm" class="bg-success text-white hover:bg-success/90 border-transparent" onclick={`openCompleteModal('${t.id}', '${v?.odometer || 0}')`}>Complete</Button>
                        <form method="post">
                          <input type="hidden" name="tripId" value={t.id} />
                          <Button type="submit" name="action" value="cancel" variant="secondary" size="sm">Cancel</Button>
                        </form>
                      </div>
                    )}
                  </div>
                </Card>
               );
            })}
          </div>
        )}
      </div>
    </div>

    <dialog id="completeTripModal" class="p-0 bg-transparent backdrop:bg-primary/20 backdrop:backdrop-blur-sm rounded-lg shadow-level-4">
      <Card variant="marketing" class="w-[400px] m-auto max-w-[90vw]">
        <div class="flex justify-between items-center mb-md">
          <h2 class="text-display-md text-ink">Complete Trip</h2>
          <button id="closeCompleteModalBtn" type="button" class="text-body hover:text-ink text-display-md leading-none">&times;</button>
        </div>
        <form method="post" class="space-y-md">
          <input type="hidden" name="action" value="complete" />
          <input type="hidden" name="tripId" id="completeTripId" />
          <p class="text-body-sm text-body mb-sm">Record final trip metrics to release the vehicle and driver back to the available pool.</p>
          <Input id="finalOdometerInput" type="number" name="finalOdometer" label="Final Odometer (km)" required />
          <Input type="number" name="fuelLiters" label="Fuel Consumed (Liters)" placeholder="e.g. 45" required />
          <Input type="number" name="fuelCost" label="Total Fuel Cost (₹)" placeholder="e.g. 4500" required />
          <Button type="submit" variant="primary" class="w-full mt-sm bg-success text-white hover:bg-success/90 border-transparent">Confirm Completion</Button>
        </form>
      </Card>
    </dialog>
  </div>

  <script is:inline>
    const completeModal = document.getElementById('completeTripModal');
    
    function openCompleteModal(tripId, currentOdometer) {
      document.getElementById('completeTripId').value = tripId;
      const odometerInput = document.getElementById('finalOdometerInput');
      odometerInput.value = currentOdometer;
      odometerInput.min = currentOdometer;
      completeModal.showModal();
    }

    document.getElementById('closeCompleteModalBtn')?.addEventListener('click', () => completeModal.close());
    
    completeModal?.addEventListener('click', (e) => {
      const dialogDimensions = completeModal.getBoundingClientRect()
      if (
        e.clientX < dialogDimensions.left || e.clientX > dialogDimensions.right ||
        e.clientY < dialogDimensions.top || e.clientY > dialogDimensions.bottom
      ) {
        completeModal.close()
      }
    })
  </script>
</Layout>

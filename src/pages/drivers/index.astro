---
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/ui/Card.astro';
import Button from '../../components/ui/Button.astro';
import Badge from '../../components/ui/Badge.astro';
import Input from '../../components/ui/Input.astro';
import { db } from '../../db';
import { drivers } from '../../db/schema';
import { eq } from 'drizzle-orm';

// Form Handling
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action');

  if (action === 'create') {
    await db.insert(drivers).values({
      id: crypto.randomUUID(),
      name: formData.get('name') as string,
      licenseNumber: formData.get('licenseNumber') as string,
      licenseCategory: formData.get('licenseCategory') as string,
      licenseExpiryDate: formData.get('licenseExpiryDate') as string,
      contactNumber: formData.get('contactNumber') as string,
      status: 'Available',
      safetyScore: 100,
    });
  } else if (action === 'delete') {
    const id = formData.get('id') as string;
    await db.delete(drivers).where(eq(drivers.id, id));
  } else if (action === 'suspend') {
    const id = formData.get('id') as string;
    await db.update(drivers).set({ status: 'Suspended' }).where(eq(drivers.id, id));
  }
}

const allDrivers = db.select().from(drivers).all();
---

<Layout title="Drivers">
  <div class="p-lg md:p-xl lg:p-4xl space-y-xl">
    <header class="flex justify-between items-end">
      <div>
        <h1 class="text-display-lg text-ink">Driver Management</h1>
        <p class="text-body-lg text-body">Manage driver profiles and compliance.</p>
      </div>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-lg">
      <div class="lg:col-span-2 space-y-md">
        {allDrivers.length === 0 ? (
          <Card variant="marketing">
            <p class="text-body text-center py-xl">No drivers found. Register one below.</p>
          </Card>
        ) : (
          <div class="flex flex-col gap-sm">
            {allDrivers.map(d => (
              <Card variant="soft" class="flex justify-between items-center px-lg py-md">
                <div>
                  <div class="flex items-center gap-sm mb-xs">
                    <span class="text-body-md-strong text-ink">{d.name}</span>
                    <Badge class={d.status === 'Available' ? 'bg-success/10 text-success' : d.status === 'Suspended' ? 'bg-error/10 text-error' : d.status === 'Off Duty' ? 'bg-mute/10 text-mute' : 'bg-primary/10 text-primary'}>{d.status}</Badge>
                  </div>
                  <div class="text-body-sm text-body flex items-center gap-xs">
                    <span>License: {d.licenseNumber} ({d.licenseCategory})</span>
                    <span>•</span>
                    <span class={new Date(d.licenseExpiryDate) < new Date() ? 'text-error font-medium' : ''}>Exp: {d.licenseExpiryDate}</span>
                    <span>•</span>
                    <span>Score: {d.safetyScore}</span>
                  </div>
                </div>
                <div class="flex gap-xs">
                  <form method="post" class="flex gap-xs">
                    <input type="hidden" name="id" value={d.id} />
                    {d.status !== 'Suspended' && (
                      <Button type="submit" name="action" value="suspend" variant="secondary" size="sm">Suspend</Button>
                    )}
                    <Button type="submit" name="action" value="delete" variant="secondary" size="sm" class="text-error hover:text-error hover:bg-error-soft border-error-soft">Remove</Button>
                  </form>
                </div>
              </Card>
            ))}
          </div>
        )}
      </div>

      <div>
        <Card variant="marketing" class="sticky top-24">
          <h2 class="text-display-md text-ink mb-md">Register Driver</h2>
          <form method="post" class="space-y-md">
            <input type="hidden" name="action" value="create" />
            <Input name="name" label="Full Name" placeholder="Alex Chen" required />
            <Input name="licenseNumber" label="License Number" placeholder="DL-123456" required />
            <div class="flex flex-col gap-2">
              <label class="text-body-sm-strong text-ink">License Category</label>
              <select name="licenseCategory" class="h-10 px-sm bg-canvas text-ink border border-hairline rounded-sm text-body-sm focus-visible:outline-none focus-visible:border-ink">
                <option value="Commercial">Commercial (Class A/B)</option>
                <option value="Standard">Standard (Class C)</option>
              </select>
            </div>
            <Input type="date" name="licenseExpiryDate" label="Expiry Date" required />
            <Input type="tel" name="contactNumber" label="Contact Number" placeholder="+1 555 0100" required />
            <Button type="submit" variant="primary" class="w-full mt-sm">Register Driver</Button>
          </form>
        </Card>
      </div>
    </div>
  </div>
</Layout>

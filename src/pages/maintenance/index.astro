---
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/ui/Card.astro';
import Button from '../../components/ui/Button.astro';
import Badge from '../../components/ui/Badge.astro';
import Input from '../../components/ui/Input.astro';
import { db } from '../../db';
import { maintenanceLogs, vehicles } from '../../db/schema';
import { eq } from 'drizzle-orm';
import { canView, canEdit, getRedirectPath } from '../../utils/auth';

const role = Astro.cookies.get('user_role')?.value;
if (!canView(role, 'fleet')) return Astro.redirect(getRedirectPath(role));
const isEditable = canEdit(role, 'fleet');

const allVehicles = db.select().from(vehicles).all();

// Form Handling
if (Astro.request.method === 'POST') {
  if (!isEditable) return Astro.redirect(getRedirectPath(role));
  const formData = await Astro.request.formData();
  const action = formData.get('action');

  if (action === 'create') {
    const vehicleId = formData.get('vehicleId') as string;
    const dateInput = formData.get('date') as string;
    const statusInput = formData.get('status') as "Active" | "Closed";

    await db.insert(maintenanceLogs).values({
      id: crypto.randomUUID(),
      vehicleId,
      description: formData.get('description') as string,
      cost: Number(formData.get('cost')),
      date: dateInput ? new Date(dateInput).toISOString() : new Date().toISOString(),
      status: statusInput,
    });
    // Set vehicle status based on log status
    if (statusInput === 'Active') {
      await db.update(vehicles).set({ status: 'In Shop' }).where(eq(vehicles.id, vehicleId));
    } else {
      await db.update(vehicles).set({ status: 'Available' }).where(eq(vehicles.id, vehicleId));
    }
  } else if (action === 'close') {
    const logId = formData.get('id') as string;
    const log = db.select().from(maintenanceLogs).where(eq(maintenanceLogs.id, logId)).get();
    if (log) {
      await db.update(maintenanceLogs).set({ status: 'Closed' }).where(eq(maintenanceLogs.id, logId));
      await db.update(vehicles).set({ status: 'Available' }).where(eq(vehicles.id, log.vehicleId));
    }
  }
}

const allLogs = db.select().from(maintenanceLogs).all();
const availableVehicles = allVehicles.filter(v => v.status === 'Available');
---

<Layout title="Maintenance">
  <div class="p-lg md:p-xl lg:p-4xl space-y-xl">
    <header class="flex justify-between items-end">
      <div>
        <h1 class="text-display-lg text-ink">Maintenance Logs</h1>
        <p class="text-body-lg text-body">Track fleet repairs and maintenance costs.</p>
      </div>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-lg">
      {isEditable && (
        <div>
          <Card variant="marketing" class="sticky top-24">
          <h2 class="text-display-md text-ink mb-md">Record Maintenance</h2>
          <form method="post" class="space-y-md">
            <input type="hidden" name="action" value="create" />
            
            <div class="flex flex-col gap-2">
              <label class="text-body-sm-strong text-ink">Vehicle</label>
              <select name="vehicleId" required class="h-10 px-sm bg-canvas text-ink border border-hairline rounded-sm text-body-sm focus-visible:outline-none focus-visible:border-ink">
                <option value="" disabled selected>Select a vehicle...</option>
                {availableVehicles.map(v => (
                  <option value={v.id}>{v.nameModel} ({v.type})</option>
                ))}
                {availableVehicles.length === 0 && <option disabled>No vehicles available</option>}
              </select>
            </div>
            
            <Input name="description" label="Service Type" placeholder="Oil change & tire rotation" required />
            <Input type="number" step="0.01" name="cost" label="Total Cost (₹)" placeholder="15000" required />
            <Input type="date" name="date" label="Date" required />
            
            <div class="flex flex-col gap-2">
              <label class="text-body-sm-strong text-ink">Status</label>
              <select name="status" required class="h-10 px-sm bg-canvas text-ink border border-hairline rounded-sm text-body-sm focus-visible:outline-none focus-visible:border-ink">
                <option value="Active">Active (In Shop)</option>
                <option value="Closed">Closed (Completed)</option>
              </select>
            </div>

            <Button type="submit" variant="primary" class="w-full mt-sm bg-warning text-black hover:bg-warning/90 border-transparent" disabled={availableVehicles.length === 0}>Save</Button>
          </form>
        </Card>
      </div>
      )}

      <div class={`space-y-md ${isEditable ? 'lg:col-span-2' : 'lg:col-span-3'}`}>
        <h2 class="text-display-md text-ink mb-md">Maintenance History</h2>
        {allLogs.length === 0 ? (
          <Card variant="marketing">
            <p class="text-body text-center py-xl">No maintenance logs found. Record one below.</p>
          </Card>
        ) : (
          <div class="bg-canvas border border-hairline rounded-lg overflow-x-auto">
            <table class="w-full text-left border-collapse whitespace-nowrap">
              <thead>
                <tr class="bg-canvas-soft border-b border-hairline text-caption-mono text-body">
                  <th class="px-md py-sm font-normal">Vehicle</th>
                  <th class="px-md py-sm font-normal">Service Type</th>
                  <th class="px-md py-sm font-normal">Cost</th>
                  <th class="px-md py-sm font-normal">Status</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-hairline">
                {allLogs.map(log => {
                   const v = allVehicles.find(v => v.id === log.vehicleId);
                   return (
                    <tr class="hover:bg-canvas-soft/50 transition-colors">
                      <td class="px-md py-sm text-body-sm-strong text-ink">{v ? `${v.nameModel} (${v.type})` : 'Unknown'}</td>
                      <td class="px-md py-sm text-body-sm text-body">{log.description}</td>
                      <td class="px-md py-sm text-body-sm text-body">₹{log.cost.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})}</td>
                      <td class="px-md py-sm">
                        <Badge class={log.status === 'Active' ? 'bg-warning/10 text-warning' : 'bg-success/10 text-success'}>{log.status === 'Active' ? 'In Shop' : 'Completed'}</Badge>
                      </td>
                    </tr>
                   );
                })}
              </tbody>
            </table>
          </div>
        )}
      </div>
    </div>
  </div>
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/ui/Card.astro';
import Button from '../../components/ui/Button.astro';
import Badge from '../../components/ui/Badge.astro';
import Input from '../../components/ui/Input.astro';
import { db } from '../../db';
import { maintenanceLogs, vehicles } from '../../db/schema';
import { eq } from 'drizzle-orm';

const allVehicles = db.select().from(vehicles).all();

// Form Handling
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action');

  if (action === 'create') {
    const vehicleId = formData.get('vehicleId') as string;
    await db.insert(maintenanceLogs).values({
      id: crypto.randomUUID(),
      vehicleId,
      description: formData.get('description') as string,
      cost: Number(formData.get('cost')),
      date: new Date().toISOString(),
      status: 'Active',
    });
    // Set vehicle to 'In Shop'
    await db.update(vehicles).set({ status: 'In Shop' }).where(eq(vehicles.id, vehicleId));
  } else if (action === 'close') {
    const logId = formData.get('id') as string;
    const log = db.select().from(maintenanceLogs).where(eq(maintenanceLogs.id, logId)).get();
    if (log) {
      await db.update(maintenanceLogs).set({ status: 'Closed' }).where(eq(maintenanceLogs.id, logId));
      await db.update(vehicles).set({ status: 'Available' }).where(eq(vehicles.id, log.vehicleId));
    }
  }
}

const allLogs = db.select().from(maintenanceLogs).all();
const availableVehicles = allVehicles.filter(v => v.status === 'Available');
---

<Layout title="Maintenance">
  <div class="p-lg md:p-xl lg:p-4xl space-y-xl">
    <header class="flex justify-between items-end">
      <div>
        <h1 class="text-display-lg text-ink">Maintenance Logs</h1>
        <p class="text-body-lg text-body">Track fleet repairs and maintenance costs.</p>
      </div>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-lg">
      <div class="lg:col-span-2 space-y-md">
        {allLogs.length === 0 ? (
          <Card variant="marketing">
            <p class="text-body text-center py-xl">No maintenance logs found. Record one below.</p>
          </Card>
        ) : (
          <div class="flex flex-col gap-sm">
            {allLogs.map(log => {
               const v = allVehicles.find(v => v.id === log.vehicleId);
               return (
                <Card variant="soft" class="flex flex-col md:flex-row justify-between md:items-center px-lg py-md gap-md">
                  <div>
                    <div class="flex items-center gap-sm mb-xs">
                      <span class="text-body-md-strong text-ink">{v?.registrationNumber}</span>
                      <Badge class={log.status === 'Active' ? 'bg-warning/10 text-warning' : 'bg-success/10 text-success'}>{log.status}</Badge>
                    </div>
                    <div class="text-body-sm text-body">
                      {log.description} • ₹{log.cost.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})} • {new Date(log.date).toLocaleDateString()}
                    </div>
                  </div>
                  <div class="flex gap-xs">
                    {log.status === 'Active' && (
                      <form method="post">
                        <input type="hidden" name="action" value="close" />
                        <input type="hidden" name="id" value={log.id} />
                        <Button type="submit" variant="primary" size="sm">Mark Completed</Button>
                      </form>
                    )}
                  </div>
                </Card>
               );
            })}
          </div>
        )}
      </div>

      <div>
        <Card variant="marketing" class="sticky top-24">
          <h2 class="text-display-md text-ink mb-md">Record Maintenance</h2>
          <form method="post" class="space-y-md">
            <input type="hidden" name="action" value="create" />
            
            <div class="flex flex-col gap-2">
              <label class="text-body-sm-strong text-ink">Vehicle</label>
              <select name="vehicleId" required class="h-10 px-sm bg-canvas text-ink border border-hairline rounded-sm text-body-sm focus-visible:outline-none focus-visible:border-ink">
                {availableVehicles.map(v => (
                  <option value={v.id}>{v.registrationNumber}</option>
                ))}
                {availableVehicles.length === 0 && <option disabled>No vehicles available</option>}
              </select>
            </div>
            
            <Input name="description" label="Description" placeholder="Oil change & tire rotation" required />
            <Input type="number" step="0.01" name="cost" label="Total Cost (₹)" placeholder="15000" required />
            
            <Button type="submit" variant="primary" class="w-full mt-sm" disabled={availableVehicles.length === 0}>Save Log</Button>
          </form>
        </Card>
      </div>
    </div>
  </div>
</Layout>

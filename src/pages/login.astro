---
import Layout from '../layouts/Layout.astro';
import Card from '../components/ui/Card.astro';
import Input from '../components/ui/Input.astro';
import Button from '../components/ui/Button.astro';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const remember = formData.get('remember') === 'on';
  
  const cookieOptions: any = { path: '/' };
  if (remember) {
    cookieOptions.maxAge = 60 * 60 * 24 * 30; // 30 days
  }
  
  Astro.cookies.set('user_role', formData.get('role')?.toString() || 'Fleet Manager', cookieOptions);
  return Astro.redirect('/');
}
---
<Layout title="Login">
  <div class="min-h-[calc(100vh-64px)] flex items-center justify-center p-md">
    <Card variant="marketing-large" class="w-full max-w-[448px] p-2xl">
      <div class="flex flex-col items-center mb-xl">
        <div class="w-12 h-12 rounded-full bg-primary flex items-center justify-center mb-md">
          <span class="text-on-primary text-display-sm tracking-tighter">TO</span>
        </div>
        <h1 class="text-display-md text-ink text-center">Log in to TransitOps</h1>
      </div>

      <form method="post" class="space-y-md">
        <Input type="email" name="email" label="Email Address" placeholder="you@company.com" pattern="[a-zA-Z0-9._%+-]+@[a-zA-Z0-9.-]+\\.com$" title="Please enter a valid .com email address" required />
        <Input type="password" name="password" label="Password" required />
        
        <div class="flex flex-col gap-2">
          <label for="role" class="text-body-sm-strong text-ink">Role</label>
          <select id="role" name="role" class="h-10 px-sm bg-canvas text-ink border border-hairline rounded-sm text-body-sm focus-visible:outline-none focus-visible:border-ink">
            <option value="Fleet Manager">Fleet Manager</option>
            <option value="Dispatcher">Dispatcher</option>
            <option value="Safety Officer">Safety Officer</option>
            <option value="Financial Analyst">Financial Analyst</option>
          </select>
        </div>

        <div class="flex items-center justify-between">
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="checkbox" name="remember" class="w-4 h-4 rounded border-hairline text-ink focus:ring-ink accent-ink" />
            <span class="text-body-sm text-ink">Remember me</span>
          </label>
          <a href="#" class="text-body-sm text-link hover:text-link-deep transition-colors">Forgot password?</a>
        </div>

        <Button type="submit" variant="primary" class="w-full mt-sm">Continue</Button>
      </form>
    </Card>
  </div>
</Layout>

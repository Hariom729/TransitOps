---
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/ui/Card.astro';
import Button from '../../components/ui/Button.astro';
import Input from '../../components/ui/Input.astro';
import { db } from '../../db';
import { fuelLogs, vehicles, trips } from '../../db/schema';

// Form Handling
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  await db.insert(fuelLogs).values({
    id: crypto.randomUUID(),
    vehicleId: formData.get('vehicleId') as string,
    liters: Number(formData.get('liters')),
    cost: Number(formData.get('cost')),
    date: new Date().toISOString(),
  });
}

const allFuelLogs = db.select().from(fuelLogs).all();
const allVehicles = db.select().from(vehicles).all();
const allTrips = db.select().from(trips).all();

const totalFuelCost = allFuelLogs.reduce((sum, log) => sum + log.cost, 0);
const totalLiters = allFuelLogs.reduce((sum, log) => sum + log.liters, 0);
const totalAcquisitionCost = allVehicles.reduce((sum, v) => sum + v.acquisitionCost, 0);
---

<Layout title="Finance">
  <div class="p-lg md:p-xl lg:p-4xl space-y-xl">
    <header class="flex justify-between items-end">
      <div>
        <h1 class="text-display-lg text-ink">Finance & Analytics</h1>
        <p class="text-body-lg text-body">Track expenses, fuel logs, and fleet ROI.</p>
      </div>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-md">
      <Card variant="soft" class="flex flex-col gap-xs min-h-[160px]">
        <span class="text-caption-mono text-body uppercase">Total Fuel Cost</span>
        <div class="text-display-xl tracking-tighter text-ink mt-auto">${totalFuelCost.toFixed(2)}</div>
        <span class="text-body-sm text-body">{totalLiters.toFixed(1)} Liters Total</span>
      </Card>
      
      <Card variant="soft" class="flex flex-col gap-xs min-h-[160px]">
        <span class="text-caption-mono text-body uppercase">Fleet Acquisition Cost</span>
        <div class="text-display-lg text-ink mt-auto">${totalAcquisitionCost.toFixed(2)}</div>
        <span class="text-body-sm text-body">{allVehicles.length} Vehicles</span>
      </Card>
      
      <Card variant="soft" class="flex flex-col gap-xs min-h-[160px]">
        <span class="text-caption-mono text-body uppercase">Completed Trips</span>
        <div class="text-display-lg text-ink mt-auto">{allTrips.filter(t => t.status === 'Completed').length}</div>
        <span class="text-body-sm text-body">Generating Revenue</span>
      </Card>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-lg">
      <div class="lg:col-span-2 space-y-md">
        <h2 class="text-display-md text-ink">Recent Fuel Logs</h2>
        {allFuelLogs.length === 0 ? (
          <Card variant="marketing">
            <p class="text-body text-center py-xl">No fuel logs recorded yet.</p>
          </Card>
        ) : (
          <div class="flex flex-col gap-sm">
            {allFuelLogs.map(log => {
               const v = allVehicles.find(v => v.id === log.vehicleId);
               return (
                <Card variant="soft" class="flex justify-between items-center px-lg py-md">
                  <div>
                    <div class="text-body-md-strong text-ink">{v?.registrationNumber} - {log.liters}L</div>
                    <div class="text-body-sm text-body">{new Date(log.date).toLocaleString()}</div>
                  </div>
                  <div class="text-display-sm text-ink">${log.cost.toFixed(2)}</div>
                </Card>
               );
            })}
          </div>
        )}
      </div>

      <div>
        <Card variant="marketing" class="sticky top-24">
          <h2 class="text-display-md text-ink mb-md">Record Fuel Log</h2>
          <form method="post" class="space-y-md">
            <div class="flex flex-col gap-2">
              <label class="text-body-sm-strong text-ink">Vehicle</label>
              <select name="vehicleId" required class="h-10 px-sm bg-canvas text-ink border border-hairline rounded-sm text-body-sm focus-visible:outline-none focus-visible:border-ink">
                {allVehicles.map(v => (
                  <option value={v.id}>{v.registrationNumber}</option>
                ))}
                {allVehicles.length === 0 && <option disabled>No vehicles available</option>}
              </select>
            </div>
            
            <Input type="number" step="0.01" name="liters" label="Volume (Liters)" placeholder="40.5" required />
            <Input type="number" step="0.01" name="cost" label="Total Cost ($)" placeholder="65.20" required />
            
            <Button type="submit" variant="primary" class="w-full mt-sm" disabled={allVehicles.length === 0}>Save Log</Button>
          </form>
        </Card>
      </div>
    </div>
  </div>
</Layout>

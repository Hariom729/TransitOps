---
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/ui/Card.astro';
import Button from '../../components/ui/Button.astro';
import Input from '../../components/ui/Input.astro';
import Badge from '../../components/ui/Badge.astro';
import { db } from '../../db';
import { fuelLogs, maintenanceLogs, vehicles, trips, expenses } from '../../db/schema';

// Form Handling
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action');

  if (action === 'log_fuel') {
    await db.insert(fuelLogs).values({
      id: crypto.randomUUID(),
      vehicleId: formData.get('vehicleId') as string,
      liters: Number(formData.get('liters')),
      cost: Number(formData.get('cost')),
      date: new Date().toISOString(),
    });
  } else if (action === 'add_expense') {
    const vId = formData.get('vehicleId') as string;
    const tId = formData.get('tripId') as string;
    await db.insert(expenses).values({
      id: crypto.randomUUID(),
      vehicleId: vId || null,
      tripId: tId || null,
      category: formData.get('category') as string,
      amount: Number(formData.get('amount')),
      date: formData.get('date') as string || new Date().toISOString(),
      description: formData.get('description') as string,
    });
  }
}

const allFuelLogs = db.select().from(fuelLogs).all();
const allMaintenanceLogs = db.select().from(maintenanceLogs).all();
const allVehicles = db.select().from(vehicles).all();
const allTrips = db.select().from(trips).all();
const allExpenses = db.select().from(expenses).all();

---

<Layout title="Finance">
  <div class="p-lg md:p-xl lg:p-4xl space-y-xl">
    <header class="flex justify-between items-end">
      <div>
        <h1 class="text-display-lg text-ink">Fuel & Expense Tracking</h1>
        <p class="text-body-lg text-body">Track expenses, fuel logs, and fleet ROI.</p>
      </div>
      <div class="flex gap-sm">
        <a href="/finance/reports">
          <Button variant="secondary" size="md">View Reports</Button>
        </a>
        <a href="/api/export-analytics.csv" download="transitops-analytics.csv">
          <Button variant="secondary" size="md">Download CSV</Button>
        </a>
        <Button variant="primary" size="md" class="bg-warning text-black hover:bg-warning/90 border-transparent" onclick="document.getElementById('recordExpenseModal').showModal()">+ Add Expense</Button>
        <Button variant="primary" size="md" class="bg-warning text-black hover:bg-warning/90 border-transparent" onclick="document.getElementById('recordFuelModal').showModal()">+ Log Fuel</Button>
      </div>
    </header>

    <div class="space-y-md">
      <h2 class="text-display-md text-ink">Recent Fuel Logs</h2>
      {allFuelLogs.length === 0 ? (
        <Card variant="marketing">
          <p class="text-body text-center py-xl">No fuel logs recorded yet.</p>
        </Card>
      ) : (
        <div class="bg-canvas border border-hairline rounded-lg overflow-x-auto">
          <table class="w-full text-left border-collapse whitespace-nowrap">
            <thead>
              <tr class="bg-canvas-soft border-b border-hairline text-caption-mono text-body">
                <th class="px-md py-sm font-normal">Vehicle</th>
                <th class="px-md py-sm font-normal">Volume (L)</th>
                <th class="px-md py-sm font-normal">Date</th>
                <th class="px-md py-sm font-normal text-right">Cost</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-hairline">
              {allFuelLogs.map(log => {
                 const v = allVehicles.find(v => v.id === log.vehicleId);
                 return (
                  <tr class="hover:bg-canvas-soft/50 transition-colors">
                    <td class="px-md py-sm text-body-sm-strong text-ink">{v ? `${v.nameModel} (${v.type})` : 'Unknown'}</td>
                    <td class="px-md py-sm text-body-sm text-body">{log.liters} L</td>
                    <td class="px-md py-sm text-body-sm text-body">{new Date(log.date).toLocaleDateString()}</td>
                    <td class="px-md py-sm text-body-sm text-body text-right">₹{log.cost.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})}</td>
                  </tr>
                 );
              })}
            </tbody>
          </table>
        </div>
      )}
    </div>

    <div class="space-y-md mt-xl">
      <h2 class="text-display-md text-ink">Trip Cost Analysis</h2>
      {allTrips.length === 0 ? (
        <Card variant="marketing">
          <p class="text-body text-center py-xl">No trips recorded yet.</p>
        </Card>
      ) : (
        <div class="bg-canvas border border-hairline rounded-lg overflow-x-auto">
          <table class="w-full text-left border-collapse whitespace-nowrap">
            <thead>
              <tr class="bg-canvas-soft border-b border-hairline text-caption-mono text-body">
                <th class="px-md py-sm font-normal">Trip</th>
                <th class="px-md py-sm font-normal">Vehicle Name</th>
                <th class="px-md py-sm font-normal text-right">Toll</th>
                <th class="px-md py-sm font-normal text-right">Other Cost</th>
                <th class="px-md py-sm font-normal text-right">Maint (Linked)</th>
                <th class="px-md py-sm font-normal text-right font-medium">Total</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-hairline">
              {allTrips.map(trip => {
                 const v = allVehicles.find(v => v.id === trip.vehicleId);
                 
                 const tripExpenses = allExpenses.filter(e => e.tripId === trip.id);
                 const tollCost = tripExpenses.filter(e => e.category.toLowerCase().includes('toll')).reduce((sum, e) => sum + e.amount, 0);
                 const otherCost = tripExpenses.filter(e => !e.category.toLowerCase().includes('toll')).reduce((sum, e) => sum + e.amount, 0);
                 const maintCost = allMaintenanceLogs.filter(m => m.tripId === trip.id).reduce((sum, m) => sum + m.cost, 0);
                 
                 const total = tollCost + otherCost + maintCost;

                 return (
                  <tr class="hover:bg-canvas-soft/50 transition-colors">
                    <td class="px-md py-sm">
                      <div class="text-body-sm-strong text-ink">TR-{trip.id.substring(0, 4).toUpperCase()}</div>
                      <div class="text-caption text-body">{trip.source} &rarr; {trip.destination}</div>
                    </td>
                    <td class="px-md py-sm text-body-sm text-body">{v ? `${v.nameModel} (${v.type})` : 'Unknown'}</td>
                    <td class="px-md py-sm text-body-sm text-body text-right">₹{tollCost.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})}</td>
                    <td class="px-md py-sm text-body-sm text-body text-right">₹{otherCost.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})}</td>
                    <td class="px-md py-sm text-body-sm text-body text-right">₹{maintCost.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})}</td>
                    <td class="px-md py-sm text-right flex items-center justify-end gap-sm h-full pt-[14px]">
                      <span class="text-body-sm-strong text-ink">₹{total.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})}</span>
                      <Badge class={trip.status === 'Completed' ? 'bg-success/10 text-success' : trip.status === 'Dispatched' ? 'bg-link/10 text-link' : trip.status === 'Cancelled' ? 'bg-error/10 text-error' : 'bg-mute/10 text-mute'}>{trip.status}</Badge>
                    </td>
                  </tr>
                 );
              })}
            </tbody>
          </table>
        </div>
      )}
    </div>

    <dialog id="recordFuelModal" class="p-0 bg-transparent backdrop:bg-primary/20 backdrop:backdrop-blur-sm rounded-lg shadow-level-4">
      <Card variant="marketing" class="w-[400px] m-auto max-w-[90vw]">
        <div class="flex justify-between items-center mb-md">
          <h2 class="text-display-md text-ink">Record Fuel Log</h2>
          <button id="closeFuelModalBtn" type="button" class="text-body hover:text-ink text-display-md leading-none">&times;</button>
        </div>
        <form method="post" class="space-y-md">
          <input type="hidden" name="action" value="log_fuel" />
          <div class="flex flex-col gap-2">
            <label class="text-body-sm-strong text-ink">Vehicle</label>
            <select name="vehicleId" required class="h-10 px-sm bg-canvas text-ink border border-hairline rounded-sm text-body-sm focus-visible:outline-none focus-visible:border-ink">
              <option value="" disabled selected>Select a vehicle...</option>
              {allVehicles.map(v => (
                <option value={v.id}>{v.nameModel} ({v.type})</option>
              ))}
              {allVehicles.length === 0 && <option disabled>No vehicles available</option>}
            </select>
          </div>
          
          <Input type="number" step="0.01" name="liters" label="Volume (Liters)" placeholder="40.5" required />
          <Input type="number" step="0.01" name="cost" label="Total Cost (₹)" placeholder="4500" required />
          
          <Button type="submit" variant="primary" class="w-full mt-sm bg-warning text-black hover:bg-warning/90 border-transparent" disabled={allVehicles.length === 0}>Add Expense and Log fuel</Button>
        </form>
      </Card>
    </dialog>

    <dialog id="recordExpenseModal" class="p-0 bg-transparent backdrop:bg-primary/20 backdrop:backdrop-blur-sm rounded-lg shadow-level-4">
      <Card variant="marketing" class="w-[400px] m-auto max-w-[90vw]">
        <div class="flex justify-between items-center mb-md">
          <h2 class="text-display-md text-ink">Add Expense</h2>
          <button id="closeExpenseModalBtn" type="button" class="text-body hover:text-ink text-display-md leading-none">&times;</button>
        </div>
        <form method="post" class="space-y-md">
          <input type="hidden" name="action" value="add_expense" />
          
          <Input name="category" label="Category" placeholder="Tolls, Permits, Supplies..." required />
          <Input name="description" label="Description" placeholder="Details about this expense" required />
          <Input type="number" step="0.01" name="amount" label="Amount (₹)" placeholder="1500" required />
          <Input type="date" name="date" label="Date" required />
          
          <div class="flex flex-col gap-2">
            <label class="text-body-sm-strong text-ink">Vehicle (Optional)</label>
            <select name="vehicleId" class="h-10 px-sm bg-canvas text-ink border border-hairline rounded-sm text-body-sm focus-visible:outline-none focus-visible:border-ink">
              <option value="">-- None (General Expense) --</option>
              {allVehicles.map(v => (
                <option value={v.id}>{v.nameModel} ({v.type})</option>
              ))}
            </select>
          </div>

          <div class="flex flex-col gap-2">
            <label class="text-body-sm-strong text-ink">Trip (Optional)</label>
            <select name="tripId" class="h-10 px-sm bg-canvas text-ink border border-hairline rounded-sm text-body-sm focus-visible:outline-none focus-visible:border-ink">
              <option value="">-- None (General Expense) --</option>
              {allTrips.map(t => (
                <option value={t.id}>{t.source} &rarr; {t.destination}</option>
              ))}
            </select>
          </div>
          
          <Button type="submit" variant="primary" class="w-full mt-sm bg-warning text-black hover:bg-warning/90 border-transparent">Save Expense</Button>
        </form>
      </Card>
    </dialog>
  </div>

  <script is:inline>
    const fuelModal = document.getElementById('recordFuelModal');
    const expenseModal = document.getElementById('recordExpenseModal');
    
    document.getElementById('closeFuelModalBtn')?.addEventListener('click', () => fuelModal.close());
    document.getElementById('closeExpenseModalBtn')?.addEventListener('click', () => expenseModal.close());
    
    fuelModal?.addEventListener('click', (e) => {
      const dialogDimensions = fuelModal.getBoundingClientRect()
      if (
        e.clientX < dialogDimensions.left || e.clientX > dialogDimensions.right ||
        e.clientY < dialogDimensions.top || e.clientY > dialogDimensions.bottom
      ) {
        fuelModal.close()
      }
    });

    expenseModal?.addEventListener('click', (e) => {
      const dialogDimensions = expenseModal.getBoundingClientRect()
      if (
        e.clientX < dialogDimensions.left || e.clientX > dialogDimensions.right ||
        e.clientY < dialogDimensions.top || e.clientY > dialogDimensions.bottom
      ) {
        expenseModal.close()
      }
    });
  </script>
</Layout>

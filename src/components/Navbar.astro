---
import Button from './ui/Button.astro';
import { hasAccess } from '../utils/auth';

const role = Astro.cookies.get('user_role')?.value;
---

<nav class="h-16 px-lg flex items-center justify-between bg-canvas border-b border-hairline sticky top-0 z-50">
  <div class="flex items-center gap-lg">
    <a href="/" class="text-display-sm text-ink flex items-center gap-2 font-semibold">
      <div class="w-8 h-8 rounded-full bg-primary flex items-center justify-center">
        <span class="text-on-primary text-body-sm-strong tracking-tighter">TO</span>
      </div>
      TransitOps
    </a>
    
    <div class="hidden md:flex items-center gap-sm">
      {hasAccess(role, '/vehicles') && <a href="/vehicles" class="text-body-sm text-body hover:text-ink px-sm py-xs rounded-full transition-colors">Vehicles</a>}
      {hasAccess(role, '/maintenance') && <a href="/maintenance" class="text-body-sm text-body hover:text-ink px-sm py-xs rounded-full transition-colors">Maintenance</a>}
      {hasAccess(role, '/drivers') && <a href="/drivers" class="text-body-sm text-body hover:text-ink px-sm py-xs rounded-full transition-colors">Drivers</a>}
      {hasAccess(role, '/trips') && <a href="/trips" class="text-body-sm text-body hover:text-ink px-sm py-xs rounded-full transition-colors">Trips</a>}
      {hasAccess(role, '/finance') && <a href="/finance" class="text-body-sm text-body hover:text-ink px-sm py-xs rounded-full transition-colors">Finance</a>}
    </div>
  </div>

  <div class="flex items-center gap-sm">
    {role ? (
      <>
        <span class="text-body-sm text-body hidden sm:inline-block">{role}</span>
        <form method="post" action="/api/logout">
          <Button type="submit" variant="nav-ask-ai" size="sm">Log Out</Button>
        </form>
      </>
    ) : (
      <a href="/login">
        <Button variant="nav-login" size="sm">Log In</Button>
      </a>
    )}
  </div>
</nav>

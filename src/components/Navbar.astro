---
import Button from './ui/Button.astro';
---

<nav class="h-16 px-lg flex items-center justify-between bg-canvas border-b border-hairline sticky top-0 z-50">
  <div class="flex items-center gap-lg">
    <a href="/" class="text-display-sm text-ink flex items-center gap-2 font-semibold">
      <div class="w-8 h-8 rounded-full bg-primary flex items-center justify-center">
        <span class="text-on-primary text-body-sm-strong tracking-tighter">TO</span>
      </div>
      TransitOps
    </a>
    
    <div class="hidden md:flex items-center gap-sm">
      <a href="/vehicles" class="text-body-sm text-body hover:text-ink px-sm py-xs rounded-full transition-colors">Vehicles</a>
      <a href="/drivers" class="text-body-sm text-body hover:text-ink px-sm py-xs rounded-full transition-colors">Drivers</a>
      <a href="/trips" class="text-body-sm text-body hover:text-ink px-sm py-xs rounded-full transition-colors">Trips</a>
      <a href="/finance" class="text-body-sm text-body hover:text-ink px-sm py-xs rounded-full transition-colors">Finance</a>
    </div>
  </div>

  <div class="flex items-center gap-xs">
    <a href="/login">
      <Button variant="nav-login" size="sm" class="hidden sm:inline-flex">Log In</Button>
    </a>
    <a href="/">
      <Button variant="nav-signup" size="sm">Dashboard</Button>
    </a>
  </div>
</nav>

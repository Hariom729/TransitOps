---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="TransitOps - Smart Transport Operations Platform" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | TransitOps</title>
        <!-- Font setup (Inter & JetBrains Mono fallbacks for demo) -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet">
	</head>
	<body class="bg-canvas-soft min-h-screen text-ink font-sans antialiased selection:bg-selection-bg selection:text-selection-fg">
    <Navbar />
    <main class="w-full">
		  <slot />
    </main>
	</body>
</html>
